# Copy this file to .env.local and fill in your Stripe keys.
# .env.local is gitignored — never commit real keys.

# Stripe secret key — use a RESTRICTED key (rk_...) scoped to:
#   Checkout Sessions: write   |   Payment Intents: read
# Test mode key starts with rk_test_, live with rk_live_.
STRIPE_SECRET_KEY=rk_test_xxx

# Stripe webhook signing secret (whsec_...).
# Local dev: run `stripe listen --forward-to localhost:3005/api/webhooks/stripe`
#   and paste the whsec_ it prints here.
# Production: create the endpoint in the Dashboard (Developers → Webhooks)
#   pointing to https://yourdomain.com/api/webhooks/stripe and copy its secret.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public site URL used to build Checkout success/cancel return URLs.
# Optional in dev (falls back to the request origin / localhost:3005).
NEXT_PUBLIC_SITE_URL=http://localhost:3005
