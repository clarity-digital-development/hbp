# Copy this file to .env.local and fill in your Stripe keys.
# .env.local is gitignored — never commit real keys.

# Stripe secret key — use a RESTRICTED key (rk_...) scoped to:
#   Checkout Sessions: write   |   Payment Intents: read
# Test mode key starts with rk_test_, live with rk_live_.
STRIPE_SECRET_KEY=rk_test_xxx

# Stripe webhook signing secret (whsec_...).
# Local dev: run `stripe listen --forward-to localhost:3005/api/webhooks/stripe`
#   and paste the whsec_ it prints here.
# Production: create the endpoint in the Dashboard (Developers → Webhooks)
#   pointing to https://yourdomain.com/api/webhooks/stripe and copy its secret.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public site URL used to build Checkout success/cancel return URLs.
# Optional in dev (falls back to the request origin / localhost:3005).
NEXT_PUBLIC_SITE_URL=http://localhost:3005

# Resend — powers the contact form (sends inquiries to bookings@…).
# Get the key at https://resend.com → API Keys.
RESEND_API_KEY=re_xxx
# "From" address — must be on a domain VERIFIED in Resend
# (add haileybrookephotography.com under Resend → Domains and set its DNS).
CONTACT_FROM_EMAIL="Hailey Brooke Photography <noreply@haileybrookephotography.com>"

# --- Admin dashboard ---
# PostgreSQL connection string. On Railway, add a PostgreSQL service and it
# injects DATABASE_URL automatically (you can reference it in the web service's
# variables as ${{Postgres.DATABASE_URL}}).
DATABASE_URL="postgresql://user:password@host:port/dbname"
# Password Hailey types to access /admin.
ADMIN_PASSWORD="choose-a-strong-password"
# Secret used to sign the admin login cookie (any long random string).
ADMIN_SESSION_SECRET="a-long-random-string"
